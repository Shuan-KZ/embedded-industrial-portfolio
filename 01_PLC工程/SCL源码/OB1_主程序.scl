ORGANIZATION_BLOCK "Main"
TITLE = '设备监控主程序'
AUTHOR : 'KuangZhiqi'
FAMILY : 'DeviceMonitor'
VERSION : 0.3
{ S7_Optimized_Access := 'FALSE' }
// 优化访问关闭：因C#上位机通过S7.NET按绝对偏移量读DB1，需固定地址

VAR_TEMP
    _t_设备编号 : DInt;
    _t_临时温度 : Real;
    _t_临时振动 : Real;
    _t_临时压力 : Real;
    _t_临时状态 : Int;
    _t_输出状态 : Int;          // FC1 阈值判定输出
    _t_循环计数 : DInt;
    _t_故障自锁标志 : Bool;
    _t_功率系数 : Real;
END_VAR

VAR CONSTANT
    TEMP_WARN_THRESHOLD : Real := 60.0;     // 温度预警阈值(°C)
    TEMP_FAULT_THRESHOLD : Real := 80.0;    // 温度故障阈值(°C)
    VIB_WARN_THRESHOLD : Real := 4.0;       // 振动预警阈值(mm/s) — 参考，实际不判定
    VIB_FAULT_THRESHOLD : Real := 7.0;      // 振动故障阈值(mm/s) — 参考，实际不判定
    SAMPLING_INTERVAL_S : Real := 2.0;      // 采样间隔(秒)
    SECONDS_PER_HOUR : Real := 3600.0;      // 小时换算常数
    UPDATE_INTERVAL_CYCLES : Int := 20;     // 能耗更新间隔(假设100ms扫描×20=2s)
END_VAR

BEGIN
    // ===== 初始化 =====
    // 采样间隔T=2s, 换算为小时: 2/3600 = 1/1800 ≈ 5.556e-4
    #_t_功率系数 := #SAMPLING_INTERVAL_S / #SECONDS_PER_HOUR;
    #_t_故障自锁标志 := TRUE;             // 故障需手动复位才恢复

    // ===== 能耗定时门控 =====
    "设备数据块".扫描周期计数 := "设备数据块".扫描周期计数 + 1;
    IF "设备数据块".扫描周期计数 >= #UPDATE_INTERVAL_CYCLES THEN
        "设备数据块".能耗更新标志 := TRUE;
        "设备数据块".扫描周期计数 := 0;
    ELSE
        "设备数据块".能耗更新标志 := FALSE;
    END_IF;

    // ===== 主循环：6设备巡检 =====
    FOR #_t_循环计数 := 0 TO 5 DO
        #_t_设备编号 := #_t_循环计数 + 1;

        CASE #_t_设备编号 OF
            1:
                #_t_临时温度 := "设备数据块".设备1温度;
                #_t_临时振动 := "设备数据块".设备1振动;
                #_t_临时压力 := "设备数据块".设备1压力;
                #_t_临时状态 := "设备数据块".设备1状态;

                "阈值判断"(
                    当前値 := #_t_临时温度,
                    预警阈值 := #TEMP_WARN_THRESHOLD,
                    故障阈值 := #TEMP_FAULT_THRESHOLD,
                    故障自锁 := #_t_故障自锁标志,
                    当前状态 := #_t_临时状态,
                    新状态 => #_t_输出状态
                );
                "设备数据块".设备1状态 := #_t_输出状态;

                IF "设备数据块".能耗更新标志 THEN
                    "设备数据块".设备1能耗 := "设备数据块".设备1能耗 + #_t_临时温度 * #_t_功率系数;
                END_IF;

            2:
                #_t_临时温度 := "设备数据块".设备2温度;
                #_t_临时振动 := "设备数据块".设备2振动;
                #_t_临时压力 := "设备数据块".设备2压力;
                #_t_临时状态 := "设备数据块".设备2状态;

                "阈值判断"(
                    当前値 := #_t_临时温度,
                    预警阈值 := #TEMP_WARN_THRESHOLD,
                    故障阈值 := #TEMP_FAULT_THRESHOLD,
                    故障自锁 := #_t_故障自锁标志,
                    当前状态 := #_t_临时状态,
                    新状态 => #_t_输出状态
                );
                "设备数据块".设备2状态 := #_t_输出状态;

                IF "设备数据块".能耗更新标志 THEN
                    "设备数据块".设备2能耗 := "设备数据块".设备2能耗 + #_t_临时温度 * #_t_功率系数;
                END_IF;

            3:
                #_t_临时温度 := "设备数据块".设备3温度;
                #_t_临时振动 := "设备数据块".设备3振动;
                #_t_临时压力 := "设备数据块".设备3压力;
                #_t_临时状态 := "设备数据块".设备3状态;

                "阈值判断"(
                    当前値 := #_t_临时温度,
                    预警阈值 := #TEMP_WARN_THRESHOLD,
                    故障阈值 := #TEMP_FAULT_THRESHOLD,
                    故障自锁 := #_t_故障自锁标志,
                    当前状态 := #_t_临时状态,
                    新状态 => #_t_输出状态
                );
                "设备数据块".设备3状态 := #_t_输出状态;

                IF "设备数据块".能耗更新标志 THEN
                    "设备数据块".设备3能耗 := "设备数据块".设备3能耗 + #_t_临时温度 * #_t_功率系数;
                END_IF;

            4:
                #_t_临时温度 := "设备数据块".设备4温度;
                #_t_临时振动 := "设备数据块".设备4振动;
                #_t_临时压力 := "设备数据块".设备4压力;
                #_t_临时状态 := "设备数据块".设备4状态;

                "阈值判断"(
                    当前値 := #_t_临时温度,
                    预警阈值 := #TEMP_WARN_THRESHOLD,
                    故障阈值 := #TEMP_FAULT_THRESHOLD,
                    故障自锁 := #_t_故障自锁标志,
                    当前状态 := #_t_临时状态,
                    新状态 => #_t_输出状态
                );
                "设备数据块".设备4状态 := #_t_输出状态;

                IF "设备数据块".能耗更新标志 THEN
                    "设备数据块".设备4能耗 := "设备数据块".设备4能耗 + #_t_临时温度 * #_t_功率系数;
                END_IF;

            5:
                #_t_临时温度 := "设备数据块".设备5温度;
                #_t_临时振动 := "设备数据块".设备5振动;
                #_t_临时压力 := "设备数据块".设备5压力;
                #_t_临时状态 := "设备数据块".设备5状态;

                "阈值判断"(
                    当前値 := #_t_临时温度,
                    预警阈值 := #TEMP_WARN_THRESHOLD,
                    故障阈值 := #TEMP_FAULT_THRESHOLD,
                    故障自锁 := #_t_故障自锁标志,
                    当前状态 := #_t_临时状态,
                    新状态 => #_t_输出状态
                );
                "设备数据块".设备5状态 := #_t_输出状态;

                IF "设备数据块".能耗更新标志 THEN
                    "设备数据块".设备5能耗 := "设备数据块".设备5能耗 + #_t_临时温度 * #_t_功率系数;
                END_IF;

            6:
                #_t_临时温度 := "设备数据块".设备6温度;
                #_t_临时振动 := "设备数据块".设备6振动;
                #_t_临时压力 := "设备数据块".设备6压力;
                #_t_临时状态 := "设备数据块".设备6状态;

                "阈值判断"(
                    当前値 := #_t_临时温度,
                    预警阈值 := #TEMP_WARN_THRESHOLD,
                    故障阈值 := #TEMP_FAULT_THRESHOLD,
                    故障自锁 := #_t_故障自锁标志,
                    当前状态 := #_t_临时状态,
                    新状态 => #_t_输出状态
                );
                "设备数据块".设备6状态 := #_t_输出状态;

                IF "设备数据块".能耗更新标志 THEN
                    "设备数据块".设备6能耗 := "设备数据块".设备6能耗 + #_t_临时温度 * #_t_功率系数;
                END_IF;

            ELSE
                CONTINUE;
        END_CASE;
    END_FOR;

END_ORGANIZATION_BLOCK
